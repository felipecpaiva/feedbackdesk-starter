# Bring your own AI provider. Copy this file to `.env.local` (gitignored) and
# set the key for whichever provider you choose to wire into src/lib/llm.ts.
# Pick ONE — you do not need all of them.

# Anthropic (Claude)
# ANTHROPIC_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Google (Gemini)
# GOOGLE_GENERATIVE_AI_API_KEY=

# A local / self-hosted OpenAI-compatible endpoint (e.g. Ollama, LM Studio)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=not-needed-for-local

# NOTE: these are server-only secrets. Do NOT prefix them with NEXT_PUBLIC_,
# and never read them from a "use client" component.
